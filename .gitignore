#-----------------------------------------------------------------------------
# ENVIRONMENTS & SECRETS
#-----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
testing.txt

#-----------------------------------------------------------------------------
# DEPENDENCIES
#-----------------------------------------------------------------------------
/vendor/
node_modules/
npm-debug.log
yarn-error.log
composer.phar

#-----------------------------------------------------------------------------
# RUNTIME, CACHES, & LOGS (Preserve Directory Structures)
#-----------------------------------------------------------------------------
/storage/app/*
!/storage/app/.gitignore
/storage/cache/*
!/storage/cache/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore
/storage/session/*
!/storage/session/.gitignore

#-----------------------------------------------------------------------------
# SYSTEM UPLOADS
#-----------------------------------------------------------------------------
/private-uploads/*
!/private-uploads/.gitignore
!/private-uploads/shared/
/public/assets/uploads/*
!/public/assets/uploads/.gitignore

#-----------------------------------------------------------------------------
# FRAMEWORK TESTING & DEBUGGING
#-----------------------------------------------------------------------------
.phpunit.cache
.phpunit.result.cache
*.log
*.tmp
*.bak

#-----------------------------------------------------------------------------
# OS & IDE
#-----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

#-----------------------------------------------------------------------------
# PROJECT SPECIFIC (Audit & Verification)
#-----------------------------------------------------------------------------
/.PENILAIAN/
/.report/
.AUDIT/
.BACKUP/
QA_AUDIT.md
QA_CATEGORIZED_ISSUES.md
SECURITY_AUDIT_REPORT.md
google*.html