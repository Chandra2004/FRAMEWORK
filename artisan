#!/usr/bin/env php
<?php

use TheFramework\Console\CommandInterface;
use TheFramework\Console\BaseCommand;

require __DIR__ . '/vendor/autoload.php';

define('BASE_PATH', __DIR__);

// ANSI Colors for the runner itself
const C_BLUE    = "\033[38;5;39m";
const C_GREEN   = "\033[38;5;28m";
const C_YELLOW  = "\033[38;5;214m";
const C_RED     = "\033[31m";
const C_RESET   = "\033[0m";
const C_BOLD    = "\033[1m";

function showHeader()
{
    echo PHP_EOL;
    echo C_BLUE . C_BOLD . " 🚀 THE FRAMEWORK" . C_RESET . C_BLUE . " Artisan CLI Engine v5.0.3" . C_RESET . PHP_EOL;
    echo C_BLUE . " ──────────────────────────────────────────────────" . C_RESET . PHP_EOL;
}

// Load routes setup for route:list
if (file_exists(__DIR__ . '/routes/web.php')) require_once __DIR__ . '/routes/web.php';

// Dynamic Command Loader
$commandsDir = __DIR__ . '/app/Console/Commands/';
$commandFiles = glob($commandsDir . '*.php');
$commands = [];

foreach ($commandFiles as $file) {
    require_once $file;
    $className = 'TheFramework\\Console\\Commands\\' . basename($file, '.php');
    if (class_exists($className)) {
        $instance = new $className();
        if ($instance instanceof CommandInterface) {
            $commands[$instance->getName()] = $instance;
        }
    }
}

// Global Args
$args = $argv;
array_shift($args); // remove script name
$commandName = $args[0] ?? 'list';
array_shift($args);

// LIST COMMAND LOGIC
if ($commandName === 'list') {
    showHeader();
    echo C_YELLOW . " Penggunaan:" . C_RESET . " php artisan [perintah] [opsi]\n\n";

    ksort($commands);
    $groups = [];
    foreach ($commands as $name => $cmd) {
        $parts = explode(':', $name);
        $group = count($parts) > 1 ? strtoupper($parts[0]) : 'GENERAL';
        $groups[$group][$name] = $cmd;
    }
    ksort($groups);

    foreach ($groups as $groupName => $groupCommands) {
        echo " " . C_BLUE . C_BOLD . $groupName . C_RESET . PHP_EOL;
        foreach ($groupCommands as $name => $cmd) {
            echo "  " . C_GREEN . str_pad($name, 30) . C_RESET . $cmd->getDescription() . PHP_EOL;
        }
        echo PHP_EOL;
    }
    exit;
}

// EXECUTE COMMAND
if (!isset($commands[$commandName])) {
    showHeader();
    echo C_RED . " ✖ ERROR  Perintah [$commandName] tidak ditemukan." . C_RESET . PHP_EOL;
    
    // Suggestion logic
    $bestMatch = null;
    $shortest = -1;
    foreach ($commands as $name => $cmd) {
        $dist = levenshtein($commandName, $name);
        if ($dist <= 3 && ($shortest < 0 || $dist < $shortest)) {
            $bestMatch = $name;
            $shortest = $dist;
        }
    }

    if ($bestMatch) {
        echo C_YELLOW . " Mungkin maksud Anda: " . C_RESET . C_GREEN . $bestMatch . C_RESET . PHP_EOL;
    }
    
    echo PHP_EOL . " Jalankan " . C_CYAN . "php artisan list" . C_RESET . " untuk melihat daftar perintah." . PHP_EOL;
    exit(1);
}

// Actual Execution
try {
    $commands[$commandName]->run($args);
} catch (\Throwable $e) {
    echo C_RED . " ✖ CRITICAL ERROR: " . $e->getMessage() . C_RESET . PHP_EOL;
    echo C_YELLOW . " File: " . $e->getFile() . ":" . $e->getLine() . C_RESET . PHP_EOL;
    exit(1);
}
