#!/usr/bin/env php
<?php

use TheFramework\Console\CommandInterface;
use TheFramework\Console\BaseCommand;

require_once __DIR__ . '/app/Helpers/helpers.php';
require __DIR__ . '/vendor/autoload.php';

define('BASE_PATH', __DIR__);
define('ROOT_DIR', __DIR__);

// Load application environment, DI container, and config
require_once __DIR__ . '/bootstrap/app.php';

// ANSI Colors for the runner itself
const C_GREEN = "\033[32m";
const C_YELLOW = "\033[33m";
const C_RED = "\033[31m";
const C_CYAN = "\033[36m";
const C_WHITE = "\033[37m";
const C_GRAY = "\033[90m";
const C_RESET = "\033[0m";
const C_BOLD = "\033[1m";
const C_BG_RED = "\033[41;37m";

function showHeader()
{
    echo PHP_EOL;
    echo C_RED . C_BOLD . "  THE FRAMEWORK " . C_RESET . C_GREEN . "v5.0.1" . C_RESET . PHP_EOL . PHP_EOL;
}

// Load routes setup for route:list
if (file_exists(__DIR__ . '/routes/web.php'))
    require_once __DIR__ . '/routes/web.php';

// Dynamic Command Loader
$commandsDir = __DIR__ . '/app/Console/Commands/';
$commandFiles = glob($commandsDir . '*.php');
$commands = [];

foreach ($commandFiles as $file) {
    require_once $file;
    $className = 'TheFramework\\Console\\Commands\\' . basename($file, '.php');
    if (class_exists($className)) {
        $instance = new $className();
        if ($instance instanceof CommandInterface) {
            $commands[$instance->getName()] = $instance;
        }
    }
}

// ── 🔥 HYBRID BRIDGE: Automatic Vendor Command Discovery 🔥 ──
// Memindai folder vendor secara cerdas untuk mendeteksi perintah Laravel/Symfony.
\TheFramework\App\Console\HybridCommandScanner::scan($commands);

// Global Args
$args = $argv;
array_shift($args); // remove script name
$commandName = $args[0] ?? 'list';
array_shift($args);

// LIST COMMAND LOGIC
if ($commandName === 'list') {
    showHeader();
    echo C_YELLOW . "  Usage:" . C_RESET . PHP_EOL;
    echo "    command [options] [arguments]\n\n";

    ksort($commands);
    $groups = [];
    foreach ($commands as $name => $cmd) {
        $parts = explode(':', $name);
        $group = count($parts) > 1 ? strtolower($parts[0]) : '';
        $groups[$group][$name] = $cmd;
    }
    ksort($groups);

    echo C_YELLOW . "  Available commands:" . C_RESET . PHP_EOL;

    foreach ($groups as $groupName => $groupCommands) {
        if ($groupName !== '') {
            echo "   " . C_YELLOW . $groupName . C_RESET . PHP_EOL;
        }
        foreach ($groupCommands as $name => $cmd) {
            echo "    " . C_GREEN . str_pad($name, 30) . C_RESET . C_GRAY . $cmd->getDescription() . C_RESET . PHP_EOL;
        }
    }
    echo PHP_EOL;
    exit;
}

// EXECUTE COMMAND
if (!isset($commands[$commandName])) {
    showHeader();
    echo C_RED . " ✖ ERROR  Perintah [$commandName] tidak ditemukan." . C_RESET . PHP_EOL;

    // Suggestion logic
    $bestMatch = null;
    $shortest = -1;
    foreach ($commands as $name => $cmd) {
        $dist = levenshtein($commandName, $name);
        if ($dist <= 3 && ($shortest < 0 || $dist < $shortest)) {
            $bestMatch = $name;
            $shortest = $dist;
        }
    }

    if ($bestMatch) {
        echo C_YELLOW . " Mungkin maksud Anda: " . C_RESET . C_GREEN . $bestMatch . C_RESET . PHP_EOL;
    }

    echo PHP_EOL . " Jalankan " . C_CYAN . "php artisan list" . C_RESET . " untuk melihat daftar perintah." . PHP_EOL;
    exit(1);
}

// Actual Execution
try {
    // === SARAN-B4-005: Handle --help flag ===
    if (in_array('--help', $args) || in_array('-h', $args)) {
        showHeader();
        echo C_YELLOW . " Command: " . C_RESET . C_BOLD . $commandName . C_RESET . PHP_EOL;
        echo C_YELLOW . " Description: " . C_RESET . $commands[$commandName]->getDescription() . PHP_EOL . PHP_EOL;
        echo C_CYAN . " Usage:" . C_RESET . PHP_EOL;
        echo "   php artisan $commandName [options] [arguments]" . PHP_EOL . PHP_EOL;
        exit(0);
    }

    $commands[$commandName]->run($args);
} catch (\Throwable $e) {
    echo C_RED . " ✖ CRITICAL ERROR: " . $e->getMessage() . C_RESET . PHP_EOL;
    echo C_YELLOW . " File: " . $e->getFile() . ":" . $e->getLine() . C_RESET . PHP_EOL;
    exit(1);
}
