# ╚══════════════════════════════════════════════════════════════╝
# 
# PANDUAN: Salin file ini menjadi ".env" lalu isi nilainya.
#          Jalankan "php artisan setup" untuk auto-generate.
#          JANGAN PERNAH commit file .env ke Git!

# ══════════════════════════════════════════════════════════════
# 🏷️  APPLICATION CORE
# ══════════════════════════════════════════════════════════════
# Nama aplikasi Anda (ditampilkan di title, email, dll.)
APP_NAME=TheFramework

# Mode aplikasi. Nilai yang didukung:
#   local       → Development di localhost (error detail, tanpa cache)
#   production  → Server live (error disembunyikan, cache aktif, keamanan maks)
#   staging     → Server testing sebelum go-live (mirip production, tapi log lebih detail)
#   testing     → Khusus saat menjalankan PHPUnit (database terpisah, tanpa session)
#   maintenance → Menampilkan halaman 503 ke semua pengunjung
#   payment     → Menampilkan halaman 402 (tagihan belum dibayar) ke pengunjung
APP_ENV=local

# Tampilkan error detail di browser? Set "false" di production!
APP_DEBUG=true

# URL dasar aplikasi (tanpa trailing slash)
BASE_URL=http://localhost:8080

# Zona waktu PHP (list: https://www.php.net/manual/en/timezones.php)
APP_TIMEZONE=Asia/Jakarta

# ══════════════════════════════════════════════════════════════
# 🌍  LOCALIZATION (Multi-Bahasa)
# ══════════════════════════════════════════════════════════════
# Bahasa default aplikasi
APP_LOCALE=id

# Bahasa cadangan jika terjemahan tidak ditemukan
APP_FALLBACK_LOCALE=en

# Daftar bahasa yang didukung (pisahkan dengan koma)
APP_SUPPORTED_LOCALES=en,id

# ══════════════════════════════════════════════════════════════
# 🔐  SECURITY KEYS
# ══════════════════════════════════════════════════════════════
# Kunci enkripsi utama (generate via: php artisan setup)
# Format: base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APP_KEY=

# Kunci untuk library defuse/php-encryption (opsional)
ENCRYPTION_KEY=

# Kunci rahasia untuk otentikasi API internal
API_SECRET_KEY=

# JWT Secret untuk token-based API authentication
JWT_SECRET=

# Masa berlaku JWT token dalam menit (default: 60 = 1 jam)
JWT_TTL=60

# ══════════════════════════════════════════════════════════════
# 🗄️  DATABASE
# ══════════════════════════════════════════════════════════════
# Driver database (saat ini didukung: mysql)
DB_CONNECTION=mysql

# Alamat server database
DB_HOST=127.0.0.1

# Port database (default MySQL: 3306)
DB_PORT=3306

# Nama database
DB_NAME=the_framework_db

# Username database
DB_USER=root

# Password database (kosongkan jika tidak ada password)
DB_PASS=

# Karakter set dan collation
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Prefix tabel (opsional, berguna jika share database)
DB_PREFIX=

# Timezone database
DB_TIMEZONE=+07:00

# Strict mode MySQL (true = lebih ketat, direkomendasikan)
DB_STRICT=true

# ══════════════════════════════════════════════════════════════
# 🔴  REDIS (Opsional — untuk cache/session/queue)
# ══════════════════════════════════════════════════════════════
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# ══════════════════════════════════════════════════════════════
# 📋  SESSION
# ══════════════════════════════════════════════════════════════
# Driver penyimpanan session (file, database, redis)
SESSION_DRIVER=file

# Masa aktif session dalam menit (default: 120 = 2 jam)
SESSION_LIFETIME=120

# Kirim cookie hanya via HTTPS? (true di production!)
SESSION_SECURE_COOKIE=false

# Cookie hanya bisa diakses oleh HTTP (bukan JavaScript)
SESSION_HTTP_ONLY=true

# SameSite policy (Lax, Strict, None)
SESSION_SAME_SITE=Lax

# ══════════════════════════════════════════════════════════════
# 📦  CACHE
# ══════════════════════════════════════════════════════════════
# Driver cache (file, array, redis)
CACHE_DRIVER=file

# Prefix key cache (hindari bentrok jika share server)
CACHE_PREFIX=tf_cache_

# Time-to-live default dalam detik (3600 = 1 jam)
CACHE_TTL=3600

# ══════════════════════════════════════════════════════════════
# 📝  LOGGING
# ══════════════════════════════════════════════════════════════
# Channel log (single, daily, stack)
LOG_CHANNEL=daily

# Level minimum yang dicatat (debug, info, notice, warning, error, critical)
LOG_LEVEL=debug

# Jumlah hari file log daily disimpan sebelum otomatis dihapus
LOG_MAX_DAYS=14

# ══════════════════════════════════════════════════════════════
# 🛡️  RATE LIMITER
# ══════════════════════════════════════════════════════════════
# Aktifkan rate limiter global?
RATE_LIMIT_ENABLED=true

# Maksimum request per IP dalam periode DECAY
RATE_LIMIT_MAX=100

# Periode reset rate limit dalam detik (120 = 2 menit)
RATE_LIMIT_DECAY=120

# Rate limit khusus untuk endpoint API
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_DECAY=60

# ══════════════════════════════════════════════════════════════
# 🌐  CORS (Cross-Origin Resource Sharing)
# ══════════════════════════════════════════════════════════════
# Domain yang diizinkan mengakses API (pisahkan dengan koma, * = semua)
CORS_ALLOWED_ORIGINS=*

# HTTP methods yang diizinkan
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Headers yang diizinkan
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-CSRF-TOKEN

# Preflight cache dalam detik
CORS_MAX_AGE=86400

# ══════════════════════════════════════════════════════════════
# 📧  EMAIL (SMTP)
# ══════════════════════════════════════════════════════════════
# Mailer transport (smtp, sendmail, log)
MAIL_MAILER=smtp

# Server SMTP
MAIL_HOST=smtp.mailtrap.io

# Port SMTP (587 untuk TLS, 465 untuk SSL, 2525 untuk Mailtrap)
MAIL_PORT=2525

# Kredensial SMTP
MAIL_USERNAME=
MAIL_PASSWORD=

# Enkripsi (tls, ssl, null)
MAIL_ENCRYPTION=tls

# Timeout koneksi SMTP dalam detik
MAIL_TIMEOUT=30

# Alamat pengirim default
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME="My App Name"

# ══════════════════════════════════════════════════════════════
# 📤  FILE UPLOAD
# ══════════════════════════════════════════════════════════════
# Direktori upload default (di luar public root = aman)
# File tidak bisa diakses langsung via URL, harus melalui route /file/serve
UPLOAD_DIR=/private-uploads

# Ukuran maksimum file dalam KB (10240 = 10MB)
UPLOAD_MAX_SIZE=10240

# Auto-convert gambar ke WebP?
UPLOAD_AUTO_WEBP=true

# Kualitas konversi WebP (1-100)
UPLOAD_WEBP_QUALITY=80

# ══════════════════════════════════════════════════════════════
# 💳  MIDTRANS PAYMENT GATEWAY
# ══════════════════════════════════════════════════════════════
# Gateway default
PAYMENT_GATEWAY=midtrans

# Kunci API Midtrans (dari dashboard.midtrans.com)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# Mode produksi Midtrans (false = Sandbox/Testing)
MIDTRANS_IS_PRODUCTION=false

# ══════════════════════════════════════════════════════════════
# 🛠️  WEB COMMAND CENTER (System Dashboard)
# ══════════════════════════════════════════════════════════════
# Aktifkan akses ke /_system/* routes?
# Set "false" setelah deployment selesai!
ALLOW_WEB_MIGRATION=false

# IP yang diizinkan mengakses system routes (pisahkan dengan koma)
# Gunakan '*' untuk mengizinkan semua (TIDAK DIREKOMENDASIKAN di production!)
SYSTEM_ALLOWED_IPS=127.0.0.1

# Basic Authentication untuk system routes (Sangat Direkomendasikan)
# Gunakan "php artisan setup" untuk generate password bcrypt
SYSTEM_AUTH_USER=
SYSTEM_AUTH_PASS=

# ══════════════════════════════════════════════════════════════
# 🚧  MAINTENANCE MODE
# ══════════════════════════════════════════════════════════════
# Aktifkan maintenance mode via .env (alternatif dari APP_ENV=maintenance)
APP_MAINTENANCE=false

# IP yang diizinkan melewati maintenance mode (untuk developer)
MAINTENANCE_IPS=127.0.0.1

# Secret URL untuk bypass maintenance (opsional)
# Contoh: /bypass-maintenance?secret=rahasia123
MAINTENANCE_SECRET=

# ══════════════════════════════════════════════════════════════
# 🐳  DOCKER / RAILWAY (Cloud Deployment)
# ══════════════════════════════════════════════════════════════
# Railway dan platform lain menyediakan variabel database secara otomatis.
# Framework akan otomatis fallback ke variabel ini jika DB_* kosong.
# MYSQLHOST=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLPORT=
# PORT=8080
