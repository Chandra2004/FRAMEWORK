APP_NAME=TheFramework
APP_ENV=local
APP_DEBUG=true
BASE_URL=http://localhost:8080
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_SUPPORTED_LOCALES=en,id

APP_KEY=
ENCRYPTION_KEY=
API_SECRET_KEY=
JWT_SECRET=
JWT_TTL=60

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=framework_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=
DB_TIMEZONE=+07:00
DB_STRICT=true

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

CACHE_DRIVER=file
CACHE_PREFIX=tf_cache_
CACHE_TTL=3600

LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_MAX_DAYS=14

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_DECAY=120
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_DECAY=60

CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-CSRF-TOKEN
CORS_MAX_AGE=86400

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=30
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME="My App Name"

UPLOAD_DIR=/private-uploads
UPLOAD_MAX_SIZE=10240
UPLOAD_AUTO_WEBP=true
UPLOAD_WEBP_QUALITY=80

PAYMENT_GATEWAY=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

ALLOW_WEB_MIGRATION=false
SYSTEM_ALLOWED_IPS=127.0.0.1
SYSTEM_AUTH_USER=
SYSTEM_AUTH_PASS=

APP_MAINTENANCE=false
MAINTENANCE_IPS=127.0.0.1
MAINTENANCE_SECRET=
